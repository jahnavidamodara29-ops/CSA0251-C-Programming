#include <stdio.h>

int main() {
    int n, a = 0, b = 1, c;

    printf("Enter n: ");
    scanf("%d", &n);

    for(int i = 2; i <= n; i++) {
        c = a + b;
        a = b;
        b = c;
    }

    if(n == 0)
        printf("Fibonacci = 0");
    else
        printf("Fibonacci = %d", b);

    return 0;
}
